{
  "manifest_version": 3,
  "name": "Ad Scanner",
  "version": "1.0.0",
  "description": "扫描当前页面的 Taboola、AdSense 和 AdX 广告数量及类型",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
